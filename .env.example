# ─── Clerk Authentication ─────────────────────────────────
# Get these from: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── Database (Amazon RDS / PostgreSQL) ───────────────────
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://postgres:REPLACE_ME@REPLACE_ME.rds.amazonaws.com:5432/veritlog

# ─── Amazon AWS ───────────────────────────────────────────
# Create an IAM user with S3 + Bedrock permissions
# Bedrock: us-east-1 region required for Nova Pro
# S3: ap-south-1 recommended for Indian data residency
AWS_ACCESS_KEY_ID=AKIA_REPLACE_ME
AWS_SECRET_ACCESS_KEY=REPLACE_ME
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=veritlog-documents

# ─── AI Models ────────────────────────────────────────────
# Get from: https://ai.google.dev/
GEMINI_API_KEY=AIza_REPLACE_ME
# AWS Bedrock uses the AWS credentials above - no separate key needed

# ─── Twilio WhatsApp ──────────────────────────────────────
# Get from: https://console.twilio.com
# For sandbox testing: https://console.twilio.com/us1/develop/sms/try-it-out/whatsapp-learn
TWILIO_ACCOUNT_SID=AC_REPLACE_ME
TWILIO_AUTH_TOKEN=REPLACE_ME
TWILIO_WHATSAPP_FROM=+14155238886
# CA partner phone (receives inbox alerts). Include country code e.g. +919876543210
WHATSAPP_CA_PHONE=+91REPLACE_ME

# ─── IMAP Email Polling ───────────────────────────────────
# Connect Veritlog to the inbox that receives govt tax notices
# Tested with Titan Mail (imap.titan.email:993) and Gmail (imap.gmail.com:993)
EMAIL_IMAP_HOST=imap.titan.email
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER=notices@yourfirm.com
EMAIL_IMAP_PASS=REPLACE_ME
# Your Clerk User ID — determines which CA firm receives emailed notices
# Find it at: Clerk Dashboard → Users → click your user → copy "User ID"
EMAIL_TENANT_ID=user_REPLACE_ME

# ─── App & Security ───────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=REPLACE_ME_WITH_RANDOM_SECRET
SHARE_TOKEN_SECRET=REPLACE_ME_WITH_RANDOM_SECRET

# ─── Pine Labs Plural (Payment Gateway) ───────────────────
# Get credentials from: https://plural.pinelabs.com → Settings → Developers
# Use UAT credentials for testing, Production credentials for live
PINE_LABS_CLIENT_ID=REPLACE_ME
PINE_LABS_CLIENT_SECRET=REPLACE_ME
# Set to "uat" for sandbox testing or "production" for live payments
PINE_LABS_ENV=uat
# Webhook secret — set a strong random value, configure in Pine Labs dashboard
PINE_LABS_WEBHOOK_SECRET=REPLACE_ME_WITH_RANDOM_SECRET

